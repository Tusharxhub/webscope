generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String       @id @default(uuid())
  name      String?
  email     String       @unique
  password  String
  logs      RequestLog[]
  createdAt DateTime     @default(now())
}

model RequestLog {
  id           String        @id @default(uuid())
  url          String
  method       String
  statusCode   Int
  responseTime Int
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  scrapedData  ScrapedData[]
  createdAt    DateTime      @default(now())
}

model ScrapedData {
  id        String     @id @default(uuid())
  requestId String
  request   RequestLog @relation(fields: [requestId], references: [id], onDelete: Cascade)
  title     String
  headings  String[]
  meta      String?
  createdAt DateTime   @default(now())
}
